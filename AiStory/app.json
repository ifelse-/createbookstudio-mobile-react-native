{
  "expo": {
    "name": "AiStory",
    "slug": "AiStory",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aistory",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.spacester.AiStory",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.260367453593-0pvjv4j4qprec86mltrd06vc43dr0isu"
            ]
          }
        ],
        "ExpoLocalization_supportsRTL": false,
        "ExpoLocalization_forcesRTL": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.spacester.AiStory"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Montserrat-Black.ttf",
            "./assets/fonts/Montserrat-BlackItalic.ttf",
            "./assets/fonts/Montserrat-Bold.ttf",
            "./assets/fonts/Montserrat-BoldItalic.ttf",
            "./assets/fonts/Montserrat-ExtraBold.ttf",
            "./assets/fonts/Montserrat-ExtraBoldItalic.ttf",
            "./assets/fonts/Montserrat-ExtraLight.ttf",
            "./assets/fonts/Montserrat-ExtraLightItalic.ttf",
            "./assets/fonts/Montserrat-Italic.ttf",
            "./assets/fonts/Montserrat-Light.ttf",
            "./assets/fonts/Montserrat-LightItalic.ttf",
            "./assets/fonts/Montserrat-Medium.ttf",
            "./assets/fonts/Montserrat-MediumItalic.ttf",
            "./assets/fonts/Montserrat-Regular.ttf",
            "./assets/fonts/Montserrat-SemiBoldItalic.ttf",
            "./assets/fonts/Montserrat-SemiBold.ttf",
            "./assets/fonts/Montserrat-Thin.ttf",
            "./assets/fonts/Montserrat-ThinItalic.ttf"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.260367453593-0pvjv4j4qprec86mltrd06vc43dr0isu"
        }
      ],
      [
        "@react-native-firebase/app",
        "@react-native-firebase/auth"
      ],
      "expo-localization",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4816553860038624~5716791413",
          "iosAppId": "ca-app-pub-4816553860038624~7938225103"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportsRTL": false,
      "forcesRTL": false,
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "51a7f049-4517-44a4-bb3c-7494f6e8479c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/51a7f049-4517-44a4-bb3c-7494f6e8479c"
    }
  }
}
